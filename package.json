{
  "name": "send-to-supernote",
  "version": "1.5.2",
  "description": "Manifest V3 Chrome extension that captures the current web page and delivers it to a Supernote (Ratta) tablet via Supernote Cloud or a self-hosted Supernote Private Cloud.",
  "private": true,
  "type": "module",
  "license": "MIT",
  "scripts": {
    "build": "vite build",
    "build:firefox": "vite build --mode firefox",
    "build:all:dev:chrome": "vite build --mode development",
    "dev": "vite build --watch --mode development",
    "dev:chrome": "npm run build:all:dev:chrome && node scripts/launch-chrome.mjs",
    "launch:chrome": "node scripts/launch-chrome.mjs",
    "launch:firefox": "node scripts/launch-firefox.mjs",
    "lint:firefox": "web-ext lint --source-dir dist-firefox",
    "zip": "node scripts/zip-artifact.mjs",
    "zip:firefox": "node scripts/zip-artifact.mjs firefox",
    "crx": "node scripts/build-crx.mjs",
    "package": "npm run build && npm run zip",
    "package:firefox": "npm run build:firefox && npm run zip:firefox",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run format:check && npm run typecheck && npm run coverage"
  },
  "dependencies": {
    "@mozilla/readability": "0.6.0",
    "html2canvas": "1.4.1",
    "jspdf": "4.2.1",
    "jszip": "3.10.1"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@samrum/vite-plugin-web-extension": "5.1.1",
    "@types/chrome": "0.1.42",
    "@vitest/coverage-v8": "4.1.7",
    "crx": "^5.0.1",
    "eslint": "10.4.0",
    "eslint-config-prettier": "10.1.8",
    "happy-dom": "^20.9.0",
    "prettier": "3.8.3",
    "sinon-chrome": "3.0.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.0",
    "vite": "8.0.14",
    "vitest": "4.1.7",
    "web-ext": "^10.3.0"
  },
  "engines": {
    "node": ">=20"
  }
}
